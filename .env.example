# ═══════════════════════════════════════════════════════════════════
#  BiblioRegister — Variables de Entorno
# ═══════════════════════════════════════════════════════════════════
# Copia este fichero como .env y ajusta los valores.
#   cp .env.example .env

# ── Seguridad ─────────────────────────────────────────────────────
# Clave secreta para sesiones y CSRF (genera una aleatoria en producción)
SECRET_KEY=cambia-esta-clave-secreta-en-produccion

# ── Base de Datos (Firestore) ──────────────────────────────────
# ID del proyecto Firebase
FIREBASE_PROJECT_ID=biblioutes
# Ruta al fichero de credenciales (solo desarrollo local)
# En Cloud Run las credenciales son automáticas.
FIREBASE_CREDENTIALS=serviceAccountKey.json

# ── Admin por defecto (solo primer arranque) ─────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=biblio2025

# ── Configuración de Biblioteca ──────────────────────────────────
MAX_LOANS_PER_STUDENT=3
DEFAULT_LOAN_DAYS=14
MAX_RENEWALS=2
